{
    "compilerOptions": {
      "target": "ESNext",
      "module": "NodeNext",
      "moduleResolution": "NodeNext",
      "lib": ["ES2024", "DOM"],
      "allowJs": true,
      "checkJs": true,
      "noEmit": true,
      "strict": false,
      "noImplicitThis": true,
      "alwaysStrict": true,
      "types": [],
      "esModuleInterop": true,
      "skipLibCheck": true,
      "declaration": true,
      "emitDeclarationOnly": true,
      "outDir": "types"
    },
    "include": ["src/**/*.js"],
    "exclude": ["**/*.test.js", "node_modules"]
  }